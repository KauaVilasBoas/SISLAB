# Base URL used by the Axios client (shared/api/http.ts).
# Leave EMPTY in development to use the Vite dev proxy (/api -> backend, same-origin, no CORS).
# In production, point it at the deployed API, e.g. https://api.sislab.example.com
VITE_API_BASE_URL=

# Target the Vite dev proxy forwards /api to. Defaults to http://localhost:5121 (SISLAB.Api http profile).
VITE_API_PROXY_TARGET=http://localhost:5121
