{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "Provider": "PostgreSQL"
  },

  "ConnectionStrings": {
    "SislabDb": ""
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "LumenIdentity": {
    "Jwt": {
      "Issuer": "PLACEHOLDER_ISSUER",
      "Audience": "PLACEHOLDER_AUDIENCE",
      "Secret": "PLACEHOLDER_SECRET_MIN_32_CHARS",
      "ExpirationMinutes": 60,
      "RefreshExpirationDays": 7
    },
    "Smtp": {
      "Host": "PLACEHOLDER_SMTP_HOST",
      "Port": 587,
      "User": "PLACEHOLDER_SMTP_USER",
      "Pass": "PLACEHOLDER_SMTP_PASS",
      "From": "noreply@sislab.local",
      "UseStartTls": true
    },
    "AppSettings": {
      "BaseUrl": "http://localhost:5000",
      "LockoutThreshold": 5,
      "LockoutDurationMinutes": 15,
      "RefreshTokenExpirationDays": 7
    }
  }
}
