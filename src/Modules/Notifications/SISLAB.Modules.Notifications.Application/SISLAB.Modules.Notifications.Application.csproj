<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Application: orquestra casos de uso (read-side Dapper, MarkAsRead command, controller do sino).
    É o ponto de entrada público (IModule), exposto ao Host. Depende de Domain + Infrastructure
    (do MESMO módulo, para delegar o wiring de DI) + Contracts + SharedKernel. Simétrico ao Inventory.
  -->
  <ItemGroup>
    <ProjectReference Include="..\SISLAB.Modules.Notifications.Domain\SISLAB.Modules.Notifications.Domain.csproj" />
    <ProjectReference Include="..\SISLAB.Modules.Notifications.Infrastructure\SISLAB.Modules.Notifications.Infrastructure.csproj" />
    <ProjectReference Include="..\SISLAB.Modules.Notifications.Contracts\SISLAB.Modules.Notifications.Contracts.csproj" />
    <ProjectReference Include="..\..\..\..\src\Shared\SISLAB.Infrastructure\SISLAB.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expõe handlers CQRS internos (queries/command) aos testes do módulo. -->
    <InternalsVisibleTo Include="SISLAB.Modules.Notifications.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Lumen's [RequirePermission] on the module's write endpoints (card [E12] #95). Conscious relaxation of
      section 8: the authorization attribute must decorate the controller hosting the action (Lumen's
      authorization attribute must decorate the controller hosting the action, so the module references
      Lumen.Authorization.AspNetCore directly, pinned to the same 3.0.0 the Identity module uses.
    -->
    <PackageReference Include="Lumen.Authorization.AspNetCore" Version="3.0.1" />
  </ItemGroup>

</Project>
