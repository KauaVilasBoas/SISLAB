<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Application: orquestra casos de uso. Depende de Domain + SharedKernel + Infrastructure (para IModule).
    Referencia a própria Infrastructure do módulo para delegar o wiring de DI (AddInventoryModule).
    Isso é intencional e simétrico ao Identity: Application é o único ponto de entrada público,
    exposto ao Host. Os testes de arquitetura validam que o Host não referencia Domain diretamente;
    Application referenciar a Infrastructure do MESMO módulo é permitido pela arquitetura modular.
  -->
  <ItemGroup>
    <ProjectReference Include="..\SISLAB.Modules.Inventory.Domain\SISLAB.Modules.Inventory.Domain.csproj" />
    <ProjectReference Include="..\SISLAB.Modules.Inventory.Infrastructure\SISLAB.Modules.Inventory.Infrastructure.csproj" />
    <!--
      Contracts: the module's public boundary (IInventoryApi + DTOs). The InventoryApi adapter
      (Application/PublicApi) implements it here, delegating to the E4/E5 read-side queries via the
      mediator. The adapter lives in Application (not Infrastructure) because Infrastructure must not
      reference Application — the queries it delegates to live in Application — so wiring it here is the
      only placement that keeps the module acyclic (E5 design note).
    -->
    <ProjectReference Include="..\SISLAB.Modules.Inventory.Contracts\SISLAB.Modules.Inventory.Contracts.csproj" />
    <ProjectReference Include="..\..\..\..\src\Shared\SISLAB.Infrastructure\SISLAB.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Audit\SISLAB.Modules.Audit.Contracts\SISLAB.Modules.Audit.Contracts.csproj" />
    <!--
      Configuration.Contracts: the public ILabConfiguration port (card [E12] #76). The Inventory write-side
      consumes it to validate a stock item's category by value (it exists and belongs to the tenant), and the
      read-side to resolve the tenant's expiry warning window. Only the Contracts assembly is referenced —
      never the Configuration Domain/Application/Infrastructure (module isolation, section 2).
    -->
    <ProjectReference Include="..\..\Configuration\SISLAB.Modules.Configuration.Contracts\SISLAB.Modules.Configuration.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Exposes internal CQRS command handlers to the module's unit tests. -->
    <InternalsVisibleTo Include="SISLAB.Modules.Inventory.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Lumen's [RequirePermission] on the module's write endpoints (card [E12] #95). This is a conscious,
      documented relaxation of section 8 ("consume Lumen only inside the Identity module"): the granular
      authorization attribute must decorate the controller that hosts the action, and Lumen's discovery
      scanner only sees ControllerActionDescriptors — a proxy attribute would be invisible to it. So the
      business modules reference Lumen.Authorization.AspNetCore directly, pinned to the same 3.0.0 the
      Identity module already uses. No alias, no wrapper.
    -->
    <PackageReference Include="Lumen.Authorization.AspNetCore" Version="3.0.1" />
  </ItemGroup>

</Project>
