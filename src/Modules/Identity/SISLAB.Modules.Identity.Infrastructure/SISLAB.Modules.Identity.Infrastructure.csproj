<Project Sdk="Microsoft.NET.Sdk">

  <!-- Infrastructure do módulo: acesso a banco, EF, implementações concretas. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expõe tipos internos (TenantContext, TenantResolutionMiddleware) aos testes do módulo. -->
    <InternalsVisibleTo Include="SISLAB.Modules.Identity.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Templates de e-mail SISLAB (renderizados pelo SislabEmailTemplateRenderer via
         GetManifestResourceStream). O logical name segue o namespace de pasta. -->
    <EmbeddedResource Include="Notifications\Templates\*.html" />
    <EmbeddedResource Include="Notifications\Templates\*.txt" />
  </ItemGroup>

  <ItemGroup>
    <!-- Infrastructure depende de Domain + Contracts (nunca de Application, evita ciclo) -->
    <ProjectReference Include="..\SISLAB.Modules.Identity.Domain\SISLAB.Modules.Identity.Domain.csproj" />
    <ProjectReference Include="..\SISLAB.Modules.Identity.Contracts\SISLAB.Modules.Identity.Contracts.csproj" />
    <!-- Shared infra: SislabDbContextBase, IUnitOfWork -->
    <ProjectReference Include="..\..\..\..\src\Shared\SISLAB.Infrastructure\SISLAB.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- EF Core + Npgsql para o DbContext do módulo -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.15" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.15">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="8.0.11" />
    <!-- Override EF Core SqlServer trazido pela Lumen para resolver conflito de versão -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.15" />

    <!-- Lumen Identity: AuthN, endpoints, migrations Postgres -->
    <PackageReference Include="Lumen.Authorization" Version="2.0.0" />
    <PackageReference Include="Lumen.Authorization.AspNetCore" Version="2.0.0" />
    <!--
      Migrations assembly stays at 1.1.1: there is no 2.0.0 of this package. It still ships the EF
      migration classes for the "Lumen" schema (referenced by name via MigrationsAssembly) that the
      2.0.0 umbrella startup service applies. The buggy SeedLumen* extensions it also exposes are NOT
      used — SISLAB owns the catalog and seeds it with its own idempotent SQL (see LumenPermissionCatalogSeeder).
    -->
    <PackageReference Include="Lumen.Authorization.Migrations.PostgreSQL" Version="1.1.1" />
    <PackageReference Include="Lumen.Identity" Version="1.0.0" />
    <PackageReference Include="Lumen.Identity.AspNetCore" Version="1.0.0" />
    <PackageReference Include="Lumen.Identity.Migrations.PostgreSQL" Version="1.0.1" />
  </ItemGroup>

</Project>
